# Digital FTE Customer Success Agent - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digital_fte
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=digital_fte
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_MAX_CONNECTIONS=20

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================
KAFKA_BROKER=localhost:9092
KAFKA_CONSUMER_GROUP=digital-fte-workers
KAFKA_TOPIC_INCOMING=fte.tickets.incoming
KAFKA_TOPIC_GMAIL=fte.tickets.gmail
KAFKA_TOPIC_WHATSAPP=fte.tickets.whatsapp
KAFKA_TOPIC_WEB=fte.tickets.web

# ============================================================================
# OPENAI API
# ============================================================================
# REQUIRED: Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# GMAIL API CONFIGURATION
# ============================================================================
# Gmail OAuth credentials (download from Google Cloud Console)
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json

# Gmail Pub/Sub topic and subscription (create in Google Cloud)
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-notifications
GMAIL_PUBSUB_SUBSCRIPTION=projects/your-project/subscriptions/gmail-subscription

# Your support email address
SUPPORT_EMAIL=support@yourcompany.com

# ============================================================================
# TWILIO WHATSAPP CONFIGURATION
# ============================================================================
# Get credentials from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATE=true

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=dev_api_key_change_in_production

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourcompany.com
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/digital-fte.log

# ============================================================================
# CHANNEL CONFIGURATION
# ============================================================================
# Maximum response lengths per channel (in words)
CHANNEL_EMAIL_MAX_RESPONSE_LENGTH=500
CHANNEL_WHATSAPP_MAX_RESPONSE_LENGTH=300
CHANNEL_WEB_MAX_RESPONSE_LENGTH=300

# WhatsApp message split threshold (characters)
CHANNEL_WHATSAPP_SPLIT_THRESHOLD=1600

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================
# Number of knowledge base search attempts
AGENT_MAX_SEARCH_ATTEMPTS=2

# Sentiment analysis threshold (0.0 to 1.0)
AGENT_SENTIMENT_THRESHOLD=0.3

# Escalation trigger keywords (comma-separated)
AGENT_ESCALATION_KEYWORDS=lawyer,legal,sue,attorney,pricing,price,cost,refund,money back

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Number of replica pods (for Kubernetes deployment)
REPLICA_COUNT=3

# ============================================================================
# OPTIONAL: ADDITIONAL INTEGRATIONS
# ============================================================================
# Slack webhook for escalation notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn-here

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
#
# 1. REQUIRED: You must set OPENAI_API_KEY for the agent to work
#
# 2. For Gmail integration:
#    - Create a Google Cloud project
#    - Enable Gmail API
#    - Create OAuth 2.0 credentials
#    - Download credentials JSON file
#    - Set up Pub/Sub topic and subscription
#
# 3. For WhatsApp integration:
#    - Create a Twilio account
#    - Get a WhatsApp-enabled phone number
#    - Configure webhook URL in Twilio console
#
# 4. For production:
#    - Change API_KEY to a strong random value
#    - Use SSL/TLS for all connections
#    - Set ENVIRONMENT=production
#    - Use managed PostgreSQL (AWS RDS, Google Cloud SQL, etc.)
#    - Use managed Kafka (Confluent Cloud, AWS MSK, etc.)
#    - Set proper CORS_ORIGINS
#
