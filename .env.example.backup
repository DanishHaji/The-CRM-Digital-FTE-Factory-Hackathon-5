# Digital FTE Customer Success Agent - Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/digital_fte
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=digital_fte
DATABASE_USER=postgres
DATABASE_PASSWORD=your_postgres_password
DATABASE_MAX_CONNECTIONS=20

# Kafka Configuration
KAFKA_BROKER=localhost:9092
KAFKA_CONSUMER_GROUP=digital-fte-workers
KAFKA_TOPIC_INCOMING=fte.tickets.incoming
KAFKA_TOPIC_GMAIL=fte.tickets.gmail
KAFKA_TOPIC_WHATSAPP=fte.tickets.whatsapp
KAFKA_TOPIC_WEB=fte.tickets.web

# OpenAI API
OPENAI_API_KEY=sk-...your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gmail API Configuration
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
GMAIL_PUBSUB_SUBSCRIPTION=projects/your-project/subscriptions/gmail-push-sub
SUPPORT_EMAIL=support@yourcompany.com

# Twilio WhatsApp Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATE=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=your_api_key_for_non_webhook_endpoints

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,https://yourcompany.com
CORS_ALLOW_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/digital-fte.log

# Channel Configuration
CHANNEL_EMAIL_MAX_RESPONSE_LENGTH=500
CHANNEL_WHATSAPP_MAX_RESPONSE_LENGTH=300
CHANNEL_WEB_MAX_RESPONSE_LENGTH=300
CHANNEL_WHATSAPP_SPLIT_THRESHOLD=1600

# Agent Configuration
AGENT_MAX_SEARCH_ATTEMPTS=2
AGENT_SENTIMENT_THRESHOLD=0.3
AGENT_ESCALATION_KEYWORDS=lawyer,legal,sue,attorney

# Kubernetes/Docker Configuration (for deployment)
ENVIRONMENT=development
REPLICA_COUNT=3
