# ==================================
# DIGITAL FTE - PRODUCTION ENVIRONMENT
# ==================================
#
# Copy this file to .env.production and fill in actual values
# NEVER commit .env.production to Git!
#
# Last Updated: 2026-03-20

# ==================================
# APPLICATION SETTINGS
# ==================================

# Environment (development, staging, production)
APP_ENV=production

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# API version
API_VERSION=1.0.0

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ==================================
# DATABASE (PostgreSQL 16)
# ==================================

# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://digitalfte:CHANGE_ME_STRONG_PASSWORD@postgres:5432/digitalfte_db

# Alternative: Individual components (if not using DATABASE_URL)
POSTGRES_USER=digitalfte
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres  # Or Cloud SQL/RDS endpoint
POSTGRES_PORT=5432
POSTGRES_DB=digitalfte_db

# Connection pool settings
DB_POOL_MIN_SIZE=10
DB_POOL_MAX_SIZE=50
DB_POOL_TIMEOUT=30

# ==================================
# AI PROVIDER (Groq AI - FREE)
# ==================================

# Groq API key (get FREE at https://console.groq.com)
GROQ_API_KEY=gsk_CHANGE_ME_YOUR_GROQ_API_KEY_HERE

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile

# AI provider identifier
AI_PROVIDER=groq

# Generation parameters
GROQ_MAX_TOKENS=1000
GROQ_TEMPERATURE=0.7
GROQ_TOP_P=0.9

# ==================================
# GMAIL INTEGRATION (Optional)
# ==================================

# Gmail API credentials file path (OAuth2 JSON)
GMAIL_CREDENTIALS_FILE=/etc/gmail/credentials.json

# Gmail OAuth2 token file path (auto-generated)
GMAIL_TOKEN_FILE=/var/lib/digitalfte/gmail_token.json

# Gmail email address to monitor
GMAIL_EMAIL=support@yourdomain.com

# Google Cloud Project ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Pub/Sub topic for Gmail notifications
GMAIL_PUBSUB_TOPIC=gmail-notifications
GMAIL_PUBSUB_SUBSCRIPTION=gmail-notifications-sub

# ==================================
# TWILIO (WhatsApp Integration)
# ==================================

# Twilio Account SID (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Twilio Auth Token (KEEP SECRET!)
TWILIO_AUTH_TOKEN=CHANGE_ME_YOUR_TWILIO_AUTH_TOKEN

# Twilio WhatsApp number (format: +1234567890)
TWILIO_WHATSAPP_NUMBER=+15558675310

# WhatsApp webhook signature validation (true/false)
TWILIO_VALIDATE_SIGNATURE=true

# ==================================
# KNOWLEDGE BASE
# ==================================

# pgvector embedding model (for semantic search)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Embedding dimension (384 for all-MiniLM-L6-v2)
EMBEDDING_DIM=384

# Number of knowledge base results to retrieve
KNOWLEDGE_BASE_TOP_K=5

# Similarity threshold for knowledge base search (0.0-1.0)
KNOWLEDGE_BASE_SIMILARITY_THRESHOLD=0.7

# ==================================
# AGENT CONFIGURATION
# ==================================

# Agent name (shown in email signatures)
AGENT_NAME=Digital FTE Customer Success Agent

# Support email (for replies)
SUPPORT_EMAIL=support@yourdomain.com

# Company name
COMPANY_NAME=Your Company

# Company website
COMPANY_WEBSITE=https://yourdomain.com

# Help center URL
HELP_CENTER_URL=https://help.yourdomain.com

# ==================================
# ESCALATION RULES
# ==================================

# Keywords that trigger human escalation (comma-separated)
ESCALATION_KEYWORDS=pricing,refund,cancel,legal,lawsuit,sue,lawyer,attorney

# Sentiment threshold for escalation (-1.0 to 1.0)
# Messages with sentiment < threshold are escalated
ESCALATION_SENTIMENT_THRESHOLD=0.3

# Human agent email for escalations
ESCALATION_EMAIL=support-team@yourdomain.com

# ==================================
# RATE LIMITING
# ==================================

# Rate limit for web support form (requests per minute per IP)
RATE_LIMIT_WEB_FORM=100

# Rate limit for ticket queries (requests per hour per email)
RATE_LIMIT_TICKET_QUERIES=1000

# ==================================
# MONITORING & OBSERVABILITY
# ==================================

# Sentry DSN (for error tracking, optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry environment
SENTRY_ENVIRONMENT=production

# Sentry traces sample rate (0.0-1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics port
PROMETHEUS_PORT=9090

# ==================================
# SECURITY
# ==================================

# JWT secret key (for API authentication, if implemented)
JWT_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_HERE

# JWT expiration time (in seconds)
JWT_EXPIRATION_SECONDS=3600

# API key for internal services (if needed)
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY

# Allowed webhook IPs (comma-separated, optional)
# Leave empty to allow all
ALLOWED_WEBHOOK_IPS=

# ==================================
# EMAIL DELIVERY (For web form responses)
# ==================================

# Email provider (smtp, sendgrid, ses)
EMAIL_PROVIDER=smtp

# SMTP settings (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=support@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_USE_TLS=true

# SendGrid API key (if using SendGrid)
SENDGRID_API_KEY=SG.CHANGE_ME_YOUR_SENDGRID_API_KEY

# AWS SES settings (if using SES)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY

# Email "From" address
EMAIL_FROM_ADDRESS=support@yourdomain.com
EMAIL_FROM_NAME=Digital FTE Support

# ==================================
# KUBERNETES / CLOUD
# ==================================

# Kubernetes namespace
K8S_NAMESPACE=digital-fte

# Pod name (auto-populated by Kubernetes)
POD_NAME=${HOSTNAME}

# Node name (auto-populated by Kubernetes)
NODE_NAME=

# Cloud provider (gcp, aws, azure, none)
CLOUD_PROVIDER=gcp

# ==================================
# FEATURE FLAGS
# ==================================

# Enable/disable channels
CHANNEL_WEB_ENABLED=true
CHANNEL_EMAIL_ENABLED=true
CHANNEL_WHATSAPP_ENABLED=true

# Enable knowledge base search
KNOWLEDGE_BASE_ENABLED=true

# Enable customer history in agent context
CUSTOMER_HISTORY_ENABLED=true

# Enable automatic ticket closure
AUTO_CLOSE_TICKETS=false

# Days until auto-close (if enabled)
AUTO_CLOSE_DAYS=7

# ==================================
# PERFORMANCE
# ==================================

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Agent processing timeout (seconds)
AGENT_TIMEOUT=10

# Database query timeout (seconds)
DB_QUERY_TIMEOUT=5

# Maximum concurrent agent requests
MAX_CONCURRENT_REQUESTS=100

# ==================================
# TESTING & DEBUG (Set to false in production!)
# ==================================

# Enable debug mode (NEVER in production!)
DEBUG=false

# Enable API docs (Swagger UI)
ENABLE_API_DOCS=false

# Skip webhook signature validation (ONLY for testing!)
SKIP_SIGNATURE_VALIDATION=false

# Mock AI responses (for testing without API costs)
MOCK_AI_RESPONSES=false

# ==================================
# BACKUP & MAINTENANCE
# ==================================

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup storage location (s3://bucket/path or gs://bucket/path)
BACKUP_STORAGE_URL=gs://your-backup-bucket/digitalfte/

# ==================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ==================================
#
# 1. Generate strong passwords using:
#    openssl rand -base64 32
#
# 2. Keep secrets secure:
#    - Use Kubernetes Secrets or cloud secret managers
#    - Never commit .env.production to Git
#    - Rotate secrets regularly
#
# 3. Required secrets in Kubernetes:
#    kubectl create secret generic groq-credentials \
#      --from-literal=api-key=$GROQ_API_KEY
#
#    kubectl create secret generic postgres-credentials \
#      --from-literal=password=$POSTGRES_PASSWORD
#
#    kubectl create secret generic twilio-credentials \
#      --from-literal=auth-token=$TWILIO_AUTH_TOKEN
#
# 4. SSL/TLS:
#    - Use Let's Encrypt for HTTPS (cert-manager)
#    - Webhooks MUST be HTTPS
#
# 5. Monitoring:
#    - Set up Prometheus + Grafana
#    - Configure Sentry for error tracking
#    - Set up log aggregation (ELK, Loki, CloudWatch)
#
# 6. Scaling:
#    - Start with 3 API replicas
#    - Configure HPA (Horizontal Pod Autoscaler)
#    - Use connection pooling for database
#
# 7. Security Checklist:
#    - [ ] DEBUG=false
#    - [ ] ENABLE_API_DOCS=false
#    - [ ] SKIP_SIGNATURE_VALIDATION=false
#    - [ ] Strong passwords (32+ characters)
#    - [ ] SSL/TLS enabled
#    - [ ] Firewall rules configured
#    - [ ] Rate limiting enabled
#    - [ ] Secrets stored in Kubernetes Secrets
#
# ==================================
