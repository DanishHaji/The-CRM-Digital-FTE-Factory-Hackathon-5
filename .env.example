# Digital FTE Customer Success Agent - Local Development Environment

# Database Configuration (PostgreSQL local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/digital_fte
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=digital_fte
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_MAX_CONNECTIONS=20

# Kafka Configuration (Optional - can be disabled for local testing)
KAFKA_BROKER=localhost:9092
KAFKA_CONSUMER_GROUP=digital-fte-workers
KAFKA_TOPIC_INCOMING=fte.tickets.incoming
KAFKA_TOPIC_GMAIL=fte.tickets.gmail
KAFKA_TOPIC_WHATSAPP=fte.tickets.whatsapp
KAFKA_TOPIC_WEB=fte.tickets.web

# AI Model Configuration - Using Groq (Free & Fast)
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI API (Optional - can use Groq instead)
OPENAI_API_KEY=sk-test
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gmail API Configuration (Optional for initial testing)
GMAIL_CREDENTIALS_FILE=credentials/gmail_credentials.json
GMAIL_TOKEN_FILE=credentials/gmail_token.json
GMAIL_PUBSUB_TOPIC=projects/your-project/topics/gmail-push
GMAIL_PUBSUB_SUBSCRIPTION=projects/your-project/subscriptions/gmail-push-sub
SUPPORT_EMAIL=support@example.com

# Twilio WhatsApp Configuration (Optional for initial testing)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATE=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_KEY=dev-api-key-12345

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE=logs/digital-fte.log

# Channel Configuration
CHANNEL_EMAIL_MAX_RESPONSE_LENGTH=500
CHANNEL_WHATSAPP_MAX_RESPONSE_LENGTH=300
CHANNEL_WEB_MAX_RESPONSE_LENGTH=300
CHANNEL_WHATSAPP_SPLIT_THRESHOLD=1600

# Agent Configuration
AGENT_MAX_SEARCH_ATTEMPTS=2
AGENT_SENTIMENT_THRESHOLD=0.3
AGENT_ESCALATION_KEYWORDS=lawyer,legal,sue,attorney

# Environment
ENVIRONMENT=development
REPLICA_COUNT=1
