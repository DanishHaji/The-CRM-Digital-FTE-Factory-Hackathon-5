# IMPORTANT: This is a TEMPLATE file
# Copy this to secrets.yaml and fill in actual values
# NEVER commit secrets.yaml to Git!
#
# Create secrets manually instead:
#   kubectl create secret generic groq-credentials \
#     --from-literal=api-key=<YOUR_GROQ_API_KEY> \
#     -n digital-fte
#
# OR use this file after filling in values:
#   kubectl apply -f secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: groq-credentials
  namespace: digital-fte
type: Opaque
stringData:
  api-key: "CHANGE_ME_YOUR_GROQ_API_KEY"  # Get FREE at https://console.groq.com

---
apiVersion: v1
kind: Secret
metadata:
  name: postgres-credentials
  namespace: digital-fte
type: Opaque
stringData:
  username: "digitalfte"
  password: "CHANGE_ME_STRONG_PASSWORD"  # Generate with: openssl rand -base64 32
  database: "digitalfte_db"

---
apiVersion: v1
kind: Secret
metadata:
  name: twilio-credentials
  namespace: digital-fte
type: Opaque
stringData:
  account-sid: "ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
  auth-token: "CHANGE_ME_YOUR_TWILIO_AUTH_TOKEN"
  whatsapp-number: "+15558675310"

---
apiVersion: v1
kind: Secret
metadata:
  name: gmail-credentials
  namespace: digital-fte
type: Opaque
data:
  # Base64 encoded Gmail OAuth2 credentials JSON
  # Create with: cat credentials.json | base64
  credentials.json: "CHANGE_ME_BASE64_ENCODED_GMAIL_CREDENTIALS"
